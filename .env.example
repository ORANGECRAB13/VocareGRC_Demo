# STT / TTS
ELEVENLABS_API_KEY=

# TTS voices
ELEVENLABS_VOICE_ID=
ELEVENLABS_MULTILINGUAL_VOICE_ID=

# LLM
CEREBRAS_API_KEY=
GROQ_API_KEY=
MISTRAL_API_KEY=

# Bin zone geocoding
GOOGLE_MAPS_API_KEY=

# Twilio — WebRTC TURN + inbound phone calls
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+61...       # The Twilio number callers dial
TRANSFER_PHONE_NUMBER=+61...     # Human agent number to transfer to

# Public URL of this server (used to auto-configure Twilio webhook on startup)
# e.g. https://your-domain.com  (no trailing slash)
PUBLIC_URL=
